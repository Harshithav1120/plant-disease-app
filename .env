# ══════════════════════════════════════════════════════
#  Flower Disease EfficientNet — Environment Config
# ══════════════════════════════════════════════════════
#
# ─── HOW TO RUN (Windows PowerShell) ──────────────────
#
# Step 1: Open PowerShell and navigate to the project folder
#   cd E:\Leaf_disease
#
# Step 2: Create a virtual environment (one-time only)
#   python -m venv venv
#
# Step 3: Activate the virtual environment
#   .\venv\Scripts\Activate.ps1
#
#   NOTE: If you get an "execution policy" error, run this first:
#     Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser
#
# Step 4: Install all required packages (one-time only)
#   pip install python-dotenv numpy matplotlib seaborn scikit-learn pillow opencv-python-headless
#   pip install torch torchvision --index-url https://download.pytorch.org/whl/cu121
#
#   NOTE: Replace cu121 with your CUDA version:
#     cu118 = CUDA 11.8 | cu121 = CUDA 12.1 | cu124 = CUDA 12.4
#     Check your CUDA version with: nvidia-smi
#
# Step 5: Set UTF-8 encoding (avoids Unicode errors on Windows)
#   $env:PYTHONIOENCODING="utf-8"
#
# Step 6: Run the training script
#   python "flower_disease_efficientnet_gpu (1).py"
#
# ─── QUICK ONE-LINER (after venv is created) ──────────
#   .\venv\Scripts\Activate.ps1; $env:PYTHONIOENCODING="utf-8"; python "flower_disease_efficientnet_gpu (1).py"
#
# ─── FOR CMD (Command Prompt) ─────────────────────────
#   cd E:\Leaf_disease
#   venv\Scripts\activate.bat
#   set PYTHONIOENCODING=utf-8
#   python "flower_disease_efficientnet_gpu (1).py"
#
# ══════════════════════════════════════════════════════

# ── Paths ──────────────────────────────────────────────
DATA_DIR=./dataset_flat_structure
SAVE_DIR=./checkpoints
RESULTS_DIR=./results

# ── Model ──────────────────────────────────────────────
# b0 recommended for 4GB VRAM GPUs (uses 224x224 images, much faster)
MODEL_VERSION=b0

# ── Training Hyperparameters ───────────────────────────
NUM_EPOCHS=20
BATCH_SIZE=16
LEARNING_RATE=3e-4
WEIGHT_DECAY=1e-4
LABEL_SMOOTHING=0.1
DROPOUT_RATE=0.35

# ── Augmentation ───────────────────────────────────────
MIXUP_ALPHA=0.3
CUTMIX_PROB=0.4

# ── Transfer Learning ─────────────────────────────────
UNFREEZE_EPOCH=8
UNFREEZE_LAST_N_BLOCKS=5

# ── Early Stopping ────────────────────────────────────
PATIENCE=12

# ── DataLoader / GPU Flags ─────────────────────────────
# NUM_WORKERS=2 gives parallelism for augmentations without too much memory
NUM_WORKERS=2
PIN_MEMORY=True
PREFETCH_FACTOR=4
PERSISTENT_WORKERS=True

# ── AMP (Automatic Mixed Precision) ───────────────────
USE_AMP=True

# ── Multi-GPU ──────────────────────────────────────────
USE_MULTI_GPU=True

# ── torch.compile (PyTorch 2.0+) ──────────────────────
COMPILE_MODEL=False

# ── TTA (Test-Time Augmentation) ──────────────────────
TTA_N=5

# ── Reproducibility ───────────────────────────────────
SEED=42

# ── CUDA Device Visibility (GPU selection) ─────────────
# Uncomment and set to select specific GPU(s), e.g. "0" or "0,1"
# CUDA_VISIBLE_DEVICES=0
